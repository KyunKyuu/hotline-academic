APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Hotline WhatsApp module
# Official WhatsApp Business phone used for CTA redirect, format example: 6281234567890
WHATSAPP_BUSINESS_PHONE=
# Meta Graph API version for WhatsApp Cloud API
WHATSAPP_API_VERSION=v23.0
# Phone Number ID from Meta developer dashboard, required for outbound replies
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp Business Account ID, useful for management and future extensions
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Permanent or system user token to call WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
# Secret string used by Meta webhook verification request
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-secure-random-string
# Default country code used when normalizing phone numbers
WHATSAPP_DEFAULT_COUNTRY_CODE=62
# Optional prefilled landing page message
WHATSAPP_PREFILLED_MESSAGE="Halo, saya ingin bertanya tentang hotline akademik."

# Turn chatbot webhook automation on or off
WA_BOT_ENABLED=true
# Welcome template sent after the first inbound chat
WA_BOT_WELCOME_MESSAGE="Halo, selamat datang di Hotline Akademik.\n\nSilakan balas dengan format berikut:\nNama: \nSemester: \nKampus: \nJurusan: "
# Referral prompt after biodata is complete
WA_BOT_REFERRAL_PROMPT="Jika punya kode referral, balas sekarang.\nJika tidak ada, balas: tidak ada"
# Final handover message after grouping is determined
WA_BOT_COMPLETION_MESSAGE="Terima kasih. Data Anda sudah kami terima dan admin akan segera menghubungi Anda."
# If true, bot asks missing biodata one by one when the template parse is incomplete
WA_BOT_FALLBACK_TO_GUIDED=true

# Analytics flags
# Track CTA clicks from landing page to WhatsApp redirect
WA_TRACK_CTA=true
# Store inbound messages as analytics events
WA_TRACK_INCOMING_MESSAGES=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
